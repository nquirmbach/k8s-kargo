# Hetzner Cloud API Token
# Get from: https://console.hetzner.cloud/projects/YOUR_PROJECT/security/tokens
HETZNER_API_TOKEN=your_hetzner_api_token_here

# Hetzner Object Storage S3 Credentials
# Get from: https://console.hetzner.com/storage/projects/YOUR_PROJECT/access-keys
AWS_ACCESS_KEY_ID=your_s3_access_key_here
AWS_SECRET_ACCESS_KEY=your_s3_secret_key_here

# Optional: Custom values (defaults are in terragrunt configs)
# HETZNER_LOCATION=hel1
# CONTROL_PLANE_NODE_TYPE=cx23
# WORKER_NODE_TYPE=cx23